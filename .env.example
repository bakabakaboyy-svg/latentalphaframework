# Supabase project settings (Project Settings > API in the Supabase dashboard)
# Safe to expose in the browser — protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service_role key — server-only, bypasses RLS. NEVER expose to the client.
SUPABASE_SERVICE_KEY=

# The Odds API key (https://the-odds-api.com), free tier = 500 requests/month
ODDS_API_KEY=

# Shared secret the /api/scrape route checks for, so only your cron job (or you)
# can trigger a scrape. Generate any random string, e.g. `openssl rand -hex 32`.
CRON_SECRET=

# SIGNALS — a second, LAF-native +EV detection engine (independent from
# quant_engine, the separate Python repo surfaced in the QUANT tab). See
# README.md's SIGNALS section.
#
# 'mock' (default): synthesizes a Pinnacle/Circa baseline from LAF's own
# already-scraped sportsbook odds. Every signal is SIMULATED and locked from
# execution. Set to 'odds_api' only after finishing OddsApiPinnacleAdapter
# in lib/adapters/pinnacleAdapter.ts and adding a real ODDS_API_KEY above.
PINNACLE_SOURCE=mock

# Discord webhook for SIGNALS alerts — create one via a channel's
# Integrations -> Webhooks -> New Webhook, then paste the URL here. Separate
# from quant_engine's own DISCORD_WEBHOOK_URL (different repo/process).
DISCORD_WEBHOOK_URL=

# Minimum EV (as a decimal, 0.03 = 3%) before SIGNALS sends a Discord alert.
# The UI's own EV slider filters independently of this.
SIGNALS_ALERT_THRESHOLD=0.03

# Static bankroll SIGNALS sizes quarter-Kelly stakes against — no compounding.
STARTING_BANKROLL=10000
KELLY_FRACTION=0.25
